# Backend (Insight Vault) — example env
# Copy to .env and fill values.

# Server
PORT=3000

# OpenAI (required for classification/summaries)
OPENAI_API_KEY=

# YouTube Data API v3 (required for YouTube/playlist features)
YOUTUBE_API_KEY=

# Google Drive integration (optional — if omitted, backend stores files locally in backend/uploads)
# NOTE: GOOGLE_SERVICE_ACCOUNT_KEY must be a *single-line JSON string*.
# Tip: on Windows, you can paste JSON in one line, or escape newlines.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Optional: share uploaded files with this email
GOOGLE_DRIVE_OWNER_EMAIL=
