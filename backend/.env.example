# Backend (Insight Vault) — example env
# Copy to .env and fill values.

# Server
PORT=3000

# OpenAI (required for classification/summaries)
OPENAI_API_KEY=

# YouTube Data API v3 (required for YouTube/playlist features)
YOUTUBE_API_KEY=

# Google Drive integration (optional — if omitted, backend stores files locally in backend/uploads)
# OAuth2 is used by the backend (client_id/secret + refresh_token).
# Service Account is no longer used by the app.
GOOGLE_SERVICE_ACCOUNT_KEY=

GOOGLE_DRIVE_FOLDER_ID=

# Google Drive integration (optional — if omitted, backend stores files locally in backend/uploads)
# OAuth2 credentials (create in Google Cloud Console → APIs & Services → Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Refresh token for offline access (required for server-side Drive access)
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_OWNER_EMAIL=

# OneDrive integration (optional). Google Drive is preferred; OneDrive acts as secondary/fallback when both are configured.
# Register an app in Microsoft Entra ID (Azure AD) and grant Microsoft Graph delegated permissions.
ONEDRIVE_CLIENT_ID=
# Optional: required only for confidential clients. Public clients can omit this.
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=common
# (Optional) Where to store files. If omitted, uses OneDrive root.
ONEDRIVE_FOLDER_ID=
# Refresh token for offline access (required for server-side OneDrive access)
ONEDRIVE_REFRESH_TOKEN=
# Scopes used during login/token refresh
ONEDRIVE_SCOPES=offline_access User.Read Files.ReadWrite.All

# Postgres (required)
# Example: Render provides a DATABASE_URL like: postgresql://user:pass@host/db
DATABASE_URL=

# Render Postgres typically requires SSL; set to true only for local non-SSL databases.
DISABLE_PG_SSL=